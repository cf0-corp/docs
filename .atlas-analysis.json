  "publicApiSurface": [
    "POST /api/lab/chat — start or continue an AI research session",
    "GET /api/lab/threads — list conversation threads",
    "GET /api/lab/threads/{thread_id}/messages — fetch thread messages",
    "POST /api/reports — generate a new equity research report",
    "GET /api/reports — list reports",
    "GET /api/reports/{report_id} — fetch report detail",
    "GET /api/filings — browse SEC filings",
    "GET /api/filings/{filing_id}/sections — read filing sections",
    "POST /api/documents — upload a document",
    "GET /api/documents — list documents",
    "GET /api/skills — list available skills",
    "POST /api/skills — create a custom skill",
    "GET /api/dashboard — fetch usage analytics",
    "GET /api/auth/me — current user profile",
    "POST /api/billing/checkout-session — start subscription checkout",
    "POST /api/billing/portal-session — open billing portal"

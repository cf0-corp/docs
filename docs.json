{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "cf0",
  "description": "The financial intelligence stack for analysts. Ask anything in plain English, get cited charts, tables, and PDF reports in minutes.",
  "colors": {
    "primary": "#1d4ed8",
    "light": "#2563eb",
    "dark": "#172554"
  },
  "favicon": "/images/favicon.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "cursor",
      "mcp",
      "add-mcp"
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Get support",
        "href": "mailto:filippo@cf0.ai"
      },
      {
        "label": "App",
        "href": "https://cf0.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://cf0.ai"
    }
  },
  "search": {
    "prompt": "Search the cf0 docs..."
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:image": "/images/cf0-docs-og.png",
      "og:image:alt": "cf0 docs — the financial intelligence stack",
      "og:image:width": "1200",
      "og:image:height": "630",
      "og:type": "website",
      "og:site_name": "cf0 docs",
      "og:locale": "en_US",
      "og:url": "https://docs.cf0.ai",
      "twitter:card": "summary_large_image",
      "twitter:image": "/images/cf0-docs-og.png",
      "twitter:image:alt": "cf0 docs — the financial intelligence stack",
      "twitter:site": "@cf0ai",
      "twitter:creator": "@cf0ai",
      "twitter:domain": "docs.cf0.ai",
      "robots": "index, follow",
      "author": "cf0",
      "application-name": "cf0 docs",
      "theme-color": "#1d4ed8"
    }
  },
  "fonts": {
    "heading": {
      "family": "Source Serif 4",
      "weight": 500,
      "format": "woff2"
    },
    "body": {
      "family": "Inter Tight",
      "format": "woff2"
    }
  },
  "redirects": [
    {
      "source": "/examples/head-to-head-comparison",
      "destination": "/examples/head-to-head",
      "permanent": true
    }
  ],
  "errors": {
    "404": {
      "title": "Page not found",
      "description": "The page you're looking for has moved or doesn't exist. Try searching, or head back to the docs home."
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/cf0ai"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Lab", "href": "/features/lab" },
          { "label": "Reports", "href": "/features/reports" },
          { "label": "Filings", "href": "/features/filings" },
          { "label": "Documents", "href": "/features/documents" },
          { "label": "Skills", "href": "/features/skills" },
          { "label": "Knowledge", "href": "/features/knowledge" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "Quickstart", "href": "/quickstart" },
          { "label": "Account setup", "href": "/account-setup" },
          { "label": "Walkthroughs", "href": "/examples/head-to-head" },
          { "label": "Changelog", "href": "/changelog" }
        ]
      },
      {
        "header": "Trust",
        "items": [
          { "label": "Security overview", "href": "/security/overview" },
          { "label": "Data governance", "href": "/security/data-governance" },
          { "label": "Observability", "href": "/security/observability" },
          { "label": "Status", "href": "https://status.cf0.ai" }
        ]
      },
      {
        "header": "Company",
        "items": [
          { "label": "Home", "href": "https://cf0.ai" },
          { "label": "Sign in", "href": "https://cf0.ai" },
          { "label": "Contact", "href": "mailto:filippo@cf0.ai" },
          { "label": "@cf0ai on X", "href": "https://x.com/cf0ai" }
        ]
      }
    ]
  },
  "banner": {
    "content": "[New] docs.cf0.ai is live — every cf0 surface, the API, and the analyst walkthroughs. [Read the changelog →](/changelog)",
    "dismissible": true
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "icon": "activity",
          "href": "https://status.cf0.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": [
              "introduction",
              "quickstart",
              "account-setup"
            ]
          },
          {
            "group": "Core features",
            "icon": "sparkles",
            "pages": [
              "features/lab",
              "features/reports",
              "features/filings",
              "features/documents",
              "features/skills",
              "features/knowledge"
            ]
          },
          {
            "group": "Workspace",
            "icon": "users",
            "pages": [
              "workspace/organizations",
              "workspace/settings",
              "workspace/dashboard"
            ]
          },
          {
            "group": "Data & sources",
            "icon": "database",
            "pages": [
              "data/overview",
              "data/sec-filings",
              "data/integrations"
            ]
          },
          {
            "group": "Security & privacy",
            "icon": "shield",
            "pages": [
              "security/overview",
              "security/authentication",
              "security/data-governance",
              "security/observability",
              "security/guardrails",
              "security/citations-and-audit"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "icon": "compass",
        "groups": [
          {
            "group": "Workflow walkthroughs",
            "pages": [
              "examples/head-to-head",
              "examples/dcf-walkthrough",
              "examples/ic-memo"
            ]
          },
          {
            "group": "Published research",
            "pages": [
              "examples/published-research",
              "examples/bricks-beat-bytes",
              "examples/fertilizer-supply-chain"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "calendar",
        "pages": [
          "changelog"
        ]
      }
    ]
  }
}

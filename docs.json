{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "cf0",
  "description": "The financial intelligence stack. Data feeds a brain that feeds Lab — the place analysts ask anything and ship cited reports in minutes.",
  "colors": {
    "primary": "#1d4ed8",
    "light": "#2563eb",
    "dark": "#172554"
  },
  "favicon": "/images/favicon.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "cursor", "mcp", "add-mcp"]
  },
  "metadata": {
    "timestamp": true
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Get support",
        "href": "mailto:hello@cf0.ai"
      },
      {
        "label": "App",
        "href": "https://cf0.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://cf0.ai"
    }
  },
  "search": {
    "prompt": "Search the cf0 docs..."
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:image": "/images/cf0-og.png",
      "og:site_name": "cf0 docs",
      "twitter:card": "summary_large_image",
      "twitter:image": "/images/cf0-og.png",
      "twitter:site": "@cf0ai"
    }
  },
  "redirects": [
    {
      "source": "/examples/head-to-head-comparison",
      "destination": "/examples/head-to-head",
      "permanent": true
    }
  ],
  "errors": {
    "404": {
      "title": "Page not found",
      "description": "The page you're looking for has moved or doesn't exist. Try searching, or head back to the docs home."
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/cf0ai"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "icon": "activity",
          "href": "https://status.cf0.ai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "account-setup"
            ]
          },
          {
            "group": "Core features",
            "pages": [
              "features/lab",
              "features/reports",
              "features/filings",
              "features/documents",
              "features/skills"
            ]
          },
          {
            "group": "Workspace",
            "pages": [
              "workspace/organizations",
              "workspace/settings",
              "workspace/dashboard"
            ]
          },
          {
            "group": "Data & sources",
            "pages": [
              "data/overview",
              "data/sec-filings",
              "data/integrations"
            ]
          },
          {
            "group": "Security & privacy",
            "pages": [
              "security/overview",
              "security/authentication"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "icon": "compass",
        "pages": [
          "examples/head-to-head"
        ]
      },
      {
        "tab": "API reference",
        "icon": "code",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview",
              "api/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/lab",
              "api/reports",
              "api/filings",
              "api/documents",
              "api/skills"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "calendar",
        "pages": [
          "changelog"
        ]
      }
    ]
  }
}
